### Laravel Padrão ###
/vendor
/node_modules
/public/storage
/public/hot
/storage/*.key
.env
.env.backup
.env.production
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

### Docker & Banco de Dados ###
# Ignora os dados persistidos do MySQL no seu computador
/docker-data/
# Ignora dumps de banco de dados que você possa colocar na raiz
*.sql
*.gz
*.sql.gz

### Específico do Sistema Atalaia/Gavião ###
# Ignora os logs customizados da classe ClassLog
/public/logs/logsistema/*.log
/app/public/logs/logsistema/*.log

# Ignora arquivos temporários (Excel e PDF gerados)
/storage/app/public/temp/*
!/storage/app/public/temp/.gitignore

# Ignora fotos dos alunos (devem ser mantidas apenas no servidor/SMB)
/storage/app/public/imagens_aluno/*
!/storage/app/public/imagens_aluno/.gitignore

# Ignora backups de sistema gerados pelo comando backup:multi-sql
/storage/app/public/backups/*
!/storage/app/public/backups/.gitignore

# Ignora assinaturas digitais (se forem enviadas via upload)
/storage/app/public/assinaturas/*

### IDEs e SO ###
.idea/
.vscode/
.DS_Store
Thumbs.db
Desktop.ini
.phpunit.result.cache
