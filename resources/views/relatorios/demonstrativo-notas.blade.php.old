                            $sum_razao = array_sum($razao);

                            // SE $sum_razao FOR MAIOR QUE 0 PRECISO LEVAR EM CONTA ESSA DISCIPLINA PARA O CALCULO DA MÉDIA FINAL

                            if($sum_razao>0){
